pico-8 cartridge // http://www.pico-8.com
version 42
__lua__
-- negapico
-- by hicchicc

-- size of character (width2
-- is user for chr >= 128)
char_width    = 5
char_width2   = 5
char_height   = 8

-- draw offset
char_offset_x = 0
char_offset_y = 0

function _init()
	memset(0x5600,0,0x800)
	local s=load_from_sprites()
	printh(s,"@clip")
end


function _draw()
cls(0)
color(7)

poke(0x5f58,0x81)
cursor(2,2)
?"◜negapico◝"
?"あいうえお かきくけこ さしすせそ"
?"たちつてと なにぬねの はひふへほ"
?"まみむめも やゆよ らりるれろ わおん\n"
?"アイウエオ カキクケコ サシスセソ"
?"タチツテト ナニヌネノ ハヒフヘホ"
?"マミムメモ ヤユヨ ラリルレロ ワヲン。\n"
?"abcdefghijklmnopqrstu"
?"vwxyz 0123456789"
?"\n!@#$%^&*()_=+{}[];:',."
?"<>/?~"
cursor()
poke(0x5f58,0)

--?"!@#$%^&*()_=+{}[];:',.<>/?~"
color(13)
--print(" [snippet copied to clipboard]",0,120)


end

function load_from_sprites()
	
	--find maximum sprite index
	--(look for any set pixel)
	maxi=0
	for i=0,255 do
	 local x0=(i%16)*8
	 local y0=(i\16)*8
	  for y=0,7 do
	 	 for x=0,7 do
	 	  if(sget(x0+x,y0+y)>0) maxi=i
	 	 end
	 	end
	end
	
	-- grab bits from each sprite
	for i=0,maxi do
	
	 local x0=(i%16)*8
	 local y0=(i\16)*8
	
	 for y=0,7 do
	 	local val=0
	 	for x=0,7 do
	 	 if sget(x0+x,y0+y)>0 then
	 	  val |= (1<<x)
	 	 end
	 	end
	 	poke(0x5600+i*8+y,val)
	 	
	 end
	
	end
	
	-- font attributes are stored
	-- in character 0
	poke(0x5600,
	 char_width,
	 char_width2,
	 char_height,
	 char_offset_x,
	 char_offset_y)
	
	-- generate string
	local str="poke(0x5600,unpack(split\""
	
	for i=0,maxi*8+7 do
		str..= peek(0x5600+i)
		if (i<maxi*8+7) str..=","
	end
	
	return str.."\"))"
end

